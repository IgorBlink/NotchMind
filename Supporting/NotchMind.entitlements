<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        NotchMind ships non-sandboxed. With sandbox off, none of the
        com.apple.security.* TCC entitlements are required — Apple Events,
        network, and file access are governed by runtime TCC prompts instead.
        We keep hardened runtime off for local debug; the notarization path
        flips it on (see ENTITLEMENTS.md).
    -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
